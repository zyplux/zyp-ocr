# Copy to .env for local dev. Loaded by `just` (set dotenv-load := true).

# --- S3-compatible blob store (MinIO locally; R2 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=totvibe
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- Pipeline ↔ Worker callback signing ---
CALLBACK_HMAC_SECRET=dev-only-hmac-secret-change-me
CALLBACK_HMAC_SECRET_PREVIOUS=

# --- Worker / public base URL (the pipeline POSTs callbacks here) ---
PUBLIC_BASE=http://web:8787

# --- Pipeline endpoint (the DO POSTs job submissions here) ---
PIPELINE_BASE=http://pipeline-api:8000

# --- vLLM (real pipeline only) ---
VLLM_BASE=http://vllm:8080
VLLM_MODEL=zai-org/GLM-OCR

# --- Reconcile alarm timeout (seconds) ---
RECONCILE_TIMEOUT_SECONDS=3600
