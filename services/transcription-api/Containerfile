# syntax=docker/dockerfile:1.7
# Multi-stage Containerfile for transcription-api.
# Stages: deps → dev (uvicorn --reload) → prod (uvicorn) → mock (--mock).
# The `mock` stage skips OCR-heavy extras (glmocr/paddle) to keep the image small.

ARG PY_VERSION=3.14

# ---------- base ----------
FROM docker.io/library/python:${PY_VERSION}-slim AS base
ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    PATH=/app/.venv/bin:/root/.local/bin:$PATH \
    PYTHONUNBUFFERED=1
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
WORKDIR /app
# Inherited by dev/prod/mock — all serve /healthz on :8000.
HEALTHCHECK --interval=5s --timeout=3s --start-period=15s --retries=10 \
    CMD curl -fsS http://127.0.0.1:8000/healthz || exit 1

# ---------- deps (workspace-aware sync, no extras) ----------
FROM base AS deps
COPY pyproject.toml uv.lock ./
COPY services/transcription-api/pyproject.toml services/transcription-api/pyproject.toml
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --package transcription-api --no-install-project

# ---------- dev (with OCR extras) ----------
FROM deps AS dev
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --package transcription-api --extra ocr --no-install-project
COPY services/transcription-api/src services/transcription-api/src
COPY services/transcription-api/pyproject.toml services/transcription-api/pyproject.toml
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --package transcription-api --extra ocr
EXPOSE 8000
CMD ["uv", "run", "--package", "transcription-api", "uvicorn", \
     "transcription_api.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

# ---------- prod ----------
FROM dev AS prod
CMD ["uv", "run", "--package", "transcription-api", "uvicorn", \
     "transcription_api.app:app", "--host", "0.0.0.0", "--port", "8000"]

# ---------- mock (no OCR extras; --mock flag bypasses glmocr/paddle imports) ----------
FROM deps AS mock
COPY services/transcription-api/src services/transcription-api/src
COPY services/transcription-api/pyproject.toml services/transcription-api/pyproject.toml
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --package transcription-api
EXPOSE 8000
CMD ["uv", "run", "--package", "transcription-api", "python", "-m", "transcription_api", "--mock", \
     "--host", "0.0.0.0", "--port", "8000"]
