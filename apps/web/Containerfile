# syntax=docker/dockerfile:1.7
# Multi-stage Containerfile for @totvibe/web (TanStack Start on Cloudflare Workers).
# Stages: deps → dev (wrangler dev) → prod (vite build artifact for `wrangler deploy`).

ARG NODE_VERSION=22
ARG PNPM_VERSION=10.26.1

# ---------- base ----------
FROM docker.io/library/node:${NODE_VERSION}-slim AS base
ARG PNPM_VERSION
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CI=1
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
WORKDIR /app

# ---------- deps ----------
# Workspace-aware install: copy lockfile + every workspace manifest, then `pnpm install`.
FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json apps/web/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile --filter @totvibe/web...

# ---------- dev ----------
FROM deps AS dev
COPY apps/web ./apps/web
EXPOSE 8787
WORKDIR /app/apps/web
CMD ["pnpm", "wrangler", "dev", "--ip", "0.0.0.0", "--port", "8787"]

# ---------- prod ----------
FROM deps AS build
COPY apps/web ./apps/web
WORKDIR /app/apps/web
RUN pnpm build

FROM base AS prod
COPY --from=build /app/apps/web/.output /app/.output
COPY --from=build /app/apps/web/wrangler.jsonc /app/wrangler.jsonc
WORKDIR /app
CMD ["npx", "wrangler", "deploy", "--dry-run"]
