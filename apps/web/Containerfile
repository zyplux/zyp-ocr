# syntax=docker/dockerfile:1.7
# Multi-stage Containerfile for @totvibe/web (TanStack Start on Cloudflare Workers).
# Stages: deps → dev (wrangler dev) → prod (vite build artifact for `wrangler deploy`).

ARG BUN_VERSION=1.3.14

# ---------- base ----------
FROM docker.io/oven/bun:${BUN_VERSION}-slim AS base
ENV CI=1
WORKDIR /app

# ---------- deps ----------
# Workspace-aware install: copy lockfile + every workspace manifest, then `bun install`.
FROM base AS deps
COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/package.json
COPY packages/eslint-plugin/package.json packages/eslint-plugin/package.json
RUN --mount=type=cache,id=bun,target=/root/.bun/install/cache \
    bun install --filter "@totvibe/web" --frozen-lockfile

# ---------- dev ----------
FROM deps AS dev
COPY apps/web ./apps/web
EXPOSE 8787
WORKDIR /app/apps/web
# wrangler dev is slow on first compile — generous start_period.
HEALTHCHECK --interval=5s --timeout=3s --start-period=30s --retries=12 \
    CMD bun -e "fetch('http://127.0.0.1:8787/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
CMD ["bun", "run", "wrangler", "dev", "--ip", "0.0.0.0", "--port", "8787"]

# ---------- prod ----------
FROM deps AS build
COPY apps/web ./apps/web
WORKDIR /app/apps/web
RUN bun run build

FROM base AS prod
COPY --from=build /app/apps/web/.output /app/.output
COPY --from=build /app/apps/web/wrangler.jsonc /app/wrangler.jsonc
WORKDIR /app
CMD ["bunx", "wrangler", "deploy", "--dry-run"]
