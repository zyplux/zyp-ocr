{
  "name": "totvibe-ocr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tests"
    ],
    "catalog": {
      "@cloudflare/vite-plugin": "^1.39.0",
      "@cloudflare/workers-types": "^4.20260528.1",
      "@hono/zod-validator": "^0.8.0",
      "@tanstack/db": "^0.6.7",
      "@tanstack/react-db": "^0.1.85",
      "@tanstack/react-router": "^1.170.8",
      "@tanstack/react-start": "^1.168.14",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@totvibe/eslint-config": "^0.1.0",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "aws4fetch": "^1.0.20",
      "bun-types": "^1.3.14",
      "drizzle-kit": "1.0.0-rc.3",
      "drizzle-orm": "1.0.0-rc.3",
      "eslint": "^10.4.1",
      "hono": "^4.12.23",
      "jsdom": "^29.1.1",
      "knip": "^6.14.2",
      "npm-check-updates": "^22.2.1",
      "prettier": "^3.8.3",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "typescript": "^6.0.3",
      "ulid": "^3.0.2",
      "vite": "^8.0.14",
      "vitest": "^4.1.7",
      "wrangler": "^4.95.0",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "knip": "knip-bun",
    "format": "prettier --write .",
    "typecheck": "tsc -p . && bun --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "upgrade": "npm-check-updates --root --workspaces --format group"
  },
  "devDependencies": {
    "@totvibe/eslint-config": "catalog:",
    "bun-types": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
