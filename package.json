{
  "name": "totvibe-ocr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tests"
    ],
    "catalog": {
      "@cloudflare/vite-plugin": ">=1.41.0 <1.42",
      "@cloudflare/workers-types": "^5.20260703.1",
      "@hono/zod-validator": "^0.8.0",
      "@tanstack/db": "^0.6.14",
      "@tanstack/react-db": "^0.1.92",
      "@tanstack/react-router": "^1.170.17",
      "@tanstack/react-start": "^1.168.27",
      "@testing-library/jest-dom": "^6.9.1",
      "@testing-library/react": "^16.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@zyplux/eslint-config": "^0.6.5",
      "aws4fetch": "^1.0.20",
      "bun-types": "^1.3.14",
      "drizzle-kit": "1.0.0-rc.3",
      "drizzle-orm": "1.0.0-rc.3",
      "eslint": "^10.6.0",
      "hono": "^4.12.27",
      "jsdom": "^29.1.1",
      "knip": "^6.24.0",
      "npm-check-updates": "^22.2.9",
      "prettier": "^3.9.4",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "typescript": "^6.0.3",
      "ulid": "^3.0.2",
      "vite": "^8.1.3",
      "vitest": "^4.1.9",
      "wrangler": "^4.107.0",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "knip": "knip-bun",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "upgrade": "npm-check-updates --root --workspaces --format group"
  },
  "devDependencies": {
    "@totvibe/tsconfig": "workspace:*",
    "@zyplux/eslint-config": "catalog:",
    "bun-types": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
